{
  "schemaVersion": 1,
  "id": "sparkwitch",
  "version": "${version}",
  "name": "SparkWitch",
  "description": "Witch faction roles and active skill framework for Spark Wathe.",
  "authors": [
    "Caecorthus"
  ],
  "license": "AGPL-3.0-only",
  "environment": "*",
  "entrypoints": {
    "main": [
      "dev.caecorthus.sparkwitch.SparkWitch"
    ],
    "client": [
      "dev.caecorthus.sparkwitch.client.SparkWitchClient"
    ],
    "lambdynlights:initializer": [
      "dev.caecorthus.sparkwitch.client.FlashlightDynamicLightsInitializer"
    ],
    "dynamiclights": [
      "dev.caecorthus.sparkwitch.client.FlashlightDynamicLightsInitializer"
    ],
    "cardinal-components": [
      "dev.caecorthus.sparkwitch.component.SparkWitchComponents"
    ]
  },
  "custom": {
    "cardinal-components": [
      "sparkwitch:player",
      "sparkwitch:role_enhancements",
      "sparkwitch:world"
    ]
  },
  "mixins": [
    "sparkwitch.mixins.json",
    {
      "config": "sparkwitch.client.mixins.json",
      "environment": "client"
    }
  ],
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": "*",
    "minecraft": "${minecraft_version}",
    "java": ">=21",
    "wathe": "${wathe_version}",
    "noellesroles": "*",
    "sparkfactionapi": ">=${sparkfactionapi_version}",
    "lambdynlights": ">=4.8.7+1.21.1",
    "cardinal-components-base": ">=${cca_version}",
    "cardinal-components-entity": ">=${cca_version}",
    "cardinal-components-world": ">=${cca_version}"
  }
}
